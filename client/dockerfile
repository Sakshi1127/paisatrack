# ── Stage 1: Build React app ──────────────────
# Why two stages?
# Stage 1 builds the app (needs Node.js, npm, all dev tools)
# Stage 2 serves it (only needs nginx, tiny and fast)
# Final image doesn't include Node.js at all - much smaller

FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

# Build React app for production
# Creates /app/dist folder with HTML, CSS, JS files
RUN npm run build

# ── Stage 2: Serve with nginx ─────────────────
# nginx = lightweight web server, perfect for serving static files
FROM nginx:alpine

# Copy built files from Stage 1 into nginx's serving folder
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy custom nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80 (default HTTP port)
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]